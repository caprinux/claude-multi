#!/usr/bin/env bash
set -euo pipefail

# ─────────────────────────────────────────────────────────────────────────────
# claude-multi — Run multiple Claude Code instances with different accounts
# ─────────────────────────────────────────────────────────────────────────────

VERSION="1.0.0"
PROFILES_DIR="${CLAUDE_MULTI_HOME:-$HOME/.claude-profiles}"
MAIN_CLAUDE_DIR="$HOME/.claude"

# Colors
RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[1;33m'
BLUE=$'\033[0;34m'
CYAN=$'\033[0;36m'
BOLD=$'\033[1m'
DIM=$'\033[2m'
NC=$'\033[0m'

# ─────────────────────────────────────────────────────────────────────────────
# Helpers
# ─────────────────────────────────────────────────────────────────────────────

die()  { printf '%s\n' "${RED}error:${NC} $*" >&2; exit 1; }
info() { printf '%s\n' "${BLUE}>>>${NC} $*"; }
warn() { printf '%s\n' "${YELLOW}warning:${NC} $*" >&2; }
ok()   { printf '%s\n' "${GREEN}ok:${NC} $*"; }

need_cmd() {
    command -v "$1" >/dev/null 2>&1 || die "'$1' is required but not found in PATH"
}

profile_dir() {
    echo "$PROFILES_DIR/$1"
}

profile_exists() {
    [[ -d "$(profile_dir "$1")" ]]
}

require_profile() {
    local name="$1"
    if [[ -z "$name" ]]; then die "profile name required"; fi
    profile_exists "$name" || die "profile '${name}' does not exist. Run: claude-multi list"
}

validate_profile_name() {
    local name="$1"
    if [[ -z "$name" ]]; then die "profile name required"; fi
    [[ "$name" =~ ^[a-zA-Z0-9_-]+$ ]] || die "profile name must be alphanumeric (hyphens and underscores allowed)"
    if [[ "$name" == "." || "$name" == ".." ]]; then die "invalid profile name"; fi
}

get_profile_email() {
    local dir
    dir="$(profile_dir "$1")"
    local state_file="$dir/.claude.json"
    if [[ -f "$state_file" ]]; then
        python3 -c "
import json, sys
try:
    d = json.load(open('$state_file'))
    acct = d.get('oauthAccount', {})
    print(acct.get('emailAddress', 'unknown'))
except: print('unknown')
" 2>/dev/null
    else
        echo "not logged in"
    fi
}

get_profile_subscription() {
    local dir
    dir="$(profile_dir "$1")"
    local cred_file="$dir/.credentials.json"
    if [[ -f "$cred_file" ]]; then
        python3 -c "
import json, sys
try:
    d = json.load(open('$cred_file'))
    oauth = d.get('claudeAiOauth', {})
    sub = oauth.get('subscriptionType', 'unknown')
    print(sub)
except: print('unknown')
" 2>/dev/null
    else
        echo "none"
    fi
}

get_profile_status() {
    local dir
    dir="$(profile_dir "$1")"
    local cred_file="$dir/.credentials.json"
    if [[ ! -f "$cred_file" ]]; then
        echo "no credentials"
        return
    fi
    # Check if token is expired
    python3 -c "
import json, time
try:
    d = json.load(open('$cred_file'))
    oauth = d.get('claudeAiOauth', {})
    expires = oauth.get('expiresAt', 0)
    has_refresh = bool(oauth.get('refreshToken', ''))
    if expires == 0:
        print('no token')
    elif expires > time.time() * 1000:
        print('active')
    elif has_refresh:
        print('expired (will auto-refresh)')
    else:
        print('expired')
except: print('unknown')
" 2>/dev/null
}

# ─────────────────────────────────────────────────────────────────────────────
# Commands
# ─────────────────────────────────────────────────────────────────────────────

cmd_save() {
    local name="${1:-}"
    validate_profile_name "$name"

    # Check that main credentials exist
    local main_creds="$MAIN_CLAUDE_DIR/.credentials.json"
    local main_state="$HOME/.claude.json"
    if [[ ! -f "$main_creds" ]]; then
        die "No credentials found in ${MAIN_CLAUDE_DIR}. Login first with: claude auth login"
    fi

    # Show what account we're saving
    local current_email="unknown"
    if [[ -f "$main_state" ]]; then
        current_email="$(python3 -c "
import json
try:
    d = json.load(open('$main_state'))
    print(d.get('oauthAccount', {}).get('emailAddress', 'unknown'))
except: print('unknown')
" 2>/dev/null)"
    fi

    # Confirm overwrite if profile exists
    if profile_exists "$name"; then
        local existing_email
        existing_email="$(get_profile_email "$name")"
        warn "Profile '${name}' already exists (${existing_email})"
        echo "Overwrite with current account (${CYAN}${current_email}${NC})? [y/N]"
        read -rp "> " confirm
        [[ "$confirm" =~ ^[yY]$ ]] || die "Aborted."
    fi

    local dir
    dir="$(profile_dir "$name")"
    mkdir -p "$dir"
    chmod 700 "$dir"

    # Copy credentials
    cp "$main_creds" "$dir/.credentials.json"
    chmod 600 "$dir/.credentials.json"

    # Copy account state
    if [[ -f "$main_state" ]]; then
        python3 -c "
import json
main = json.load(open('$main_state'))
state = {}
for key in ('oauthAccount', 'hasAvailableSubscription'):
    if key in main:
        state[key] = main[key]
with open('$dir/.claude.json', 'w') as f:
    json.dump(state, f, indent=2)
" 2>/dev/null
        chmod 600 "$dir/.claude.json"
    fi

    # Sync settings
    if [[ -f "$MAIN_CLAUDE_DIR/settings.json" ]]; then
        cp "$MAIN_CLAUDE_DIR/settings.json" "$dir/settings.json"
    fi

    local sub
    sub="$(get_profile_subscription "$name")"
    ok "Saved profile '${BOLD}${name}${NC}' — ${CYAN}${current_email}${NC} (${sub})"
}

cmd_login() {
    local name="${1:-}"
    validate_profile_name "$name"

    local dir
    dir="$(profile_dir "$name")"
    mkdir -p "$dir"
    chmod 700 "$dir"

    # Sync shared settings from main config if this is a new profile
    if [[ ! -f "$dir/settings.json" ]] && [[ -f "$MAIN_CLAUDE_DIR/settings.json" ]]; then
        cp "$MAIN_CLAUDE_DIR/settings.json" "$dir/settings.json"
    fi

    # Sync plugins/skills/commands
    sync_settings_to_profile "$name" 2>/dev/null || true

    info "Opening a shell for profile '${BOLD}${name}${NC}'"
    info "Login from this shell — credentials will be saved directly to the profile."
    echo ""
    echo "  Run ${BOLD}claude${NC} and use ${BOLD}/login${NC}, or run ${BOLD}claude auth login${NC}"
    echo "  Type ${BOLD}exit${NC} when done."
    echo ""

    CLAUDE_CONFIG_DIR="$dir" PS1="(claude:${name}) \$ " exec "$SHELL"
}

cmd_list() {
    mkdir -p "$PROFILES_DIR"

    local profiles=()
    while IFS= read -r -d '' d; do
        profiles+=("$(basename "$d")")
    done < <(find "$PROFILES_DIR" -mindepth 1 -maxdepth 1 -type d -print0 2>/dev/null | sort -z)

    if [[ ${#profiles[@]} -eq 0 ]]; then
        echo "${DIM}No profiles yet. Create one with:${NC} claude-multi login <name>"
        return
    fi

    echo ""
    printf "  ${BOLD}%-20s %-35s %-15s %-25s${NC}\n" "PROFILE" "EMAIL" "PLAN" "STATUS"
    printf "  %-20s %-35s %-15s %-25s\n" "───────" "─────" "────" "──────"

    for name in "${profiles[@]}"; do
        local email sub status
        email="$(get_profile_email "$name")"
        sub="$(get_profile_subscription "$name")"
        status="$(get_profile_status "$name")"

        local status_color="$NC"
        case "$status" in
            active*)                status_color="$GREEN" ;;
            "expired (will auto"*)  status_color="$YELLOW" ;;
            expired|"no token"|"no credentials") status_color="$RED" ;;
        esac

        printf "  %-20s %-35s %-15s ${status_color}%-25s${NC}\n" \
            "$name" "$email" "$sub" "$status"
    done
    echo ""
}

cmd_run() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then die "usage: claude-multi run <profile> [claude args...]"; fi
    require_profile "$name"
    shift

    local dir
    dir="$(profile_dir "$name")"

    # Sync settings before running if main config has newer settings
    sync_settings_if_needed "$name"

    local email
    email="$(get_profile_email "$name")"
    info "Running Claude Code as ${CYAN}${email}${NC} (profile: ${BOLD}${name}${NC})"
    echo ""

    exec env CLAUDE_CONFIG_DIR="$dir" claude "$@"
}

cmd_status() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        # Show status for all profiles
        cmd_list
        return
    fi
    require_profile "$name"

    local dir
    dir="$(profile_dir "$name")"

    info "Auth status for profile '${BOLD}${name}${NC}':"
    echo ""
    CLAUDE_CONFIG_DIR="$dir" claude auth status 2>&1 || true
}

cmd_delete() {
    local name="${1:-}"
    validate_profile_name "$name"
    require_profile "$name"

    local dir
    dir="$(profile_dir "$name")"

    local email
    email="$(get_profile_email "$name")"

    echo "Delete profile '${BOLD}${name}${NC}' (${email})?"
    read -rp "Type the profile name to confirm: " confirm
    [[ "$confirm" == "$name" ]] || die "Aborted."

    # Logout first to invalidate tokens
    info "Logging out..."
    CLAUDE_CONFIG_DIR="$dir" claude auth logout 2>/dev/null || true

    rm -rf "$dir"
    ok "Profile '${name}' deleted."
}

cmd_logout() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then die "usage: claude-multi logout <profile>"; fi
    require_profile "$name"

    local dir
    dir="$(profile_dir "$name")"

    info "Logging out profile '${BOLD}${name}${NC}'..."
    CLAUDE_CONFIG_DIR="$dir" claude auth logout
    ok "Profile '${name}' logged out."
}

cmd_rename() {
    local old="${1:-}"
    local new="${2:-}"
    if [[ -z "$old" || -z "$new" ]]; then die "usage: claude-multi rename <old-name> <new-name>"; fi
    validate_profile_name "$old"
    validate_profile_name "$new"
    require_profile "$old"
    if profile_exists "$new"; then die "profile '${new}' already exists"; fi

    mv "$(profile_dir "$old")" "$(profile_dir "$new")"
    ok "Renamed '${old}' -> '${new}'"
}

cmd_sync() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then die "usage: claude-multi sync <profile>"; fi
    require_profile "$name"

    sync_settings_to_profile "$name"
    ok "Settings synced to profile '${name}'"
}

sync_settings_to_profile() {
    local name="$1"
    local dir
    dir="$(profile_dir "$name")"

    # Sync settings files
    for file in settings.json settings.local.json; do
        if [[ -f "$MAIN_CLAUDE_DIR/$file" ]]; then
            cp "$MAIN_CLAUDE_DIR/$file" "$dir/$file"
        fi
    done

    # Sync plugins directory
    if [[ -d "$MAIN_CLAUDE_DIR/plugins" ]]; then
        mkdir -p "$dir/plugins"
        rsync -a --delete "$MAIN_CLAUDE_DIR/plugins/" "$dir/plugins/" 2>/dev/null \
            || cp -a "$MAIN_CLAUDE_DIR/plugins/"* "$dir/plugins/" 2>/dev/null || true
    fi

    # Sync skills directory
    if [[ -d "$MAIN_CLAUDE_DIR/skills" ]]; then
        mkdir -p "$dir/skills"
        rsync -a --delete "$MAIN_CLAUDE_DIR/skills/" "$dir/skills/" 2>/dev/null \
            || cp -a "$MAIN_CLAUDE_DIR/skills/"* "$dir/skills/" 2>/dev/null || true
    fi

    # Sync commands directory
    if [[ -d "$MAIN_CLAUDE_DIR/commands" ]]; then
        mkdir -p "$dir/commands"
        rsync -a --delete "$MAIN_CLAUDE_DIR/commands/" "$dir/commands/" 2>/dev/null \
            || cp -a "$MAIN_CLAUDE_DIR/commands/"* "$dir/commands/" 2>/dev/null || true
    fi
}

sync_settings_if_needed() {
    local name="$1"
    local dir
    dir="$(profile_dir "$name")"

    # Only sync if main settings.json is newer than profile's
    if [[ -f "$MAIN_CLAUDE_DIR/settings.json" ]]; then
        if [[ ! -f "$dir/settings.json" ]] || [[ "$MAIN_CLAUDE_DIR/settings.json" -nt "$dir/settings.json" ]]; then
            cp "$MAIN_CLAUDE_DIR/settings.json" "$dir/settings.json"
        fi
    fi
    if [[ -f "$MAIN_CLAUDE_DIR/settings.local.json" ]]; then
        if [[ ! -f "$dir/settings.local.json" ]] || [[ "$MAIN_CLAUDE_DIR/settings.local.json" -nt "$dir/settings.local.json" ]]; then
            cp "$MAIN_CLAUDE_DIR/settings.local.json" "$dir/settings.local.json"
        fi
    fi
}

cmd_which() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then die "usage: claude-multi which <profile>"; fi
    require_profile "$name"
    echo "$(profile_dir "$name")"
}

cmd_shell() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then die "usage: claude-multi shell <profile>"; fi
    require_profile "$name"

    local dir
    dir="$(profile_dir "$name")"
    local email
    email="$(get_profile_email "$name")"

    info "Opening shell with CLAUDE_CONFIG_DIR set to profile '${BOLD}${name}${NC}' (${email})"
    info "Any 'claude' commands in this shell will use this profile."
    info "Type 'exit' to return to your normal shell."
    echo ""

    CLAUDE_CONFIG_DIR="$dir" PS1="(claude:${name}) \$ " exec "$SHELL"
}

cmd_help() {
    cat <<EOF

${BOLD}claude-multi${NC} v${VERSION} — Run multiple Claude Code instances with different accounts

${BOLD}USAGE${NC}
    claude-multi <command> [args]

${BOLD}ACCOUNT MANAGEMENT${NC}
    login   <profile>              Open a shell to login and save credentials to a profile
    save    <profile>              Save currently logged-in account as a named profile
    logout  <profile>              Logout a profile (invalidate tokens)
    status  [profile]              Show auth status (all profiles if no name given)
    list                           List all profiles with account info
    delete  <profile>              Delete a profile and its credentials
    rename  <old> <new>            Rename a profile

${BOLD}RUNNING CLAUDE${NC}
    run     <profile> [args...]    Run Claude Code using a specific profile
    shell   <profile>              Open a subshell with the profile's config active

${BOLD}CONFIGURATION${NC}
    sync    <profile>              Sync settings/plugins from main ~/.claude to profile
    which   <profile>              Print the config directory path for a profile

${BOLD}EXAMPLES${NC}
    ${DIM}# Login to an account and save it as a profile${NC}
    claude-multi login work       ${DIM}# opens shell, login there, then exit${NC}

    ${DIM}# Or save the currently logged-in account directly${NC}
    claude-multi save personal

    ${DIM}# Run Claude with your work account${NC}
    claude-multi run work

    ${DIM}# Run Claude with personal account in a specific directory${NC}
    claude-multi run personal -p "fix the tests"

    ${DIM}# Run two instances simultaneously (in separate terminals)${NC}
    claude-multi run work           ${DIM}# terminal 1${NC}
    claude-multi run personal       ${DIM}# terminal 2${NC}

    ${DIM}# Open a shell where all 'claude' commands use the work profile${NC}
    claude-multi shell work

${BOLD}ENVIRONMENT${NC}
    CLAUDE_MULTI_HOME    Override profiles directory (default: ~/.claude-profiles)

EOF
}

# ─────────────────────────────────────────────────────────────────────────────
# Main
# ─────────────────────────────────────────────────────────────────────────────

main() {
    need_cmd claude
    need_cmd python3

    local cmd="${1:-help}"
    shift 2>/dev/null || true

    case "$cmd" in
        save|s)         cmd_save "$@" ;;
        login)          cmd_login "$@" ;;
        list|ls)        cmd_list "$@" ;;
        run|r)          cmd_run "$@" ;;
        status|st)      cmd_status "$@" ;;
        delete|rm)      cmd_delete "$@" ;;
        logout)         cmd_logout "$@" ;;
        rename|mv)      cmd_rename "$@" ;;
        sync)           cmd_sync "$@" ;;
        which)          cmd_which "$@" ;;
        shell|sh)       cmd_shell "$@" ;;
        help|--help|-h) cmd_help ;;
        version|--version|-v) echo "claude-multi v${VERSION}" ;;
        *)              die "unknown command '${cmd}'. Run 'claude-multi help' for usage." ;;
    esac
}

main "$@"
